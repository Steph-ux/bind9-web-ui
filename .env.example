# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Session ───────────────────────────────────────────────────
# Mandatory in production. Random in dev if omitted.
SESSION_SECRET=

# ── Database ──────────────────────────────────────────────────
# sqlite (default) | postgresql | mysql
DB_TYPE=sqlite
# SQLite: path relative to project root
# PostgreSQL: postgresql://user:pass@host:5432/dbname
# MySQL: mysql://user:pass@host:3306/dbname
DATABASE_URL=data/bind9admin.db

# ── BIND9 (local mode) ───────────────────────────────────────
BIND9_CONF_DIR=/etc/bind
BIND9_ZONE_DIR=/var/cache/bind
RNDC_BIN=rndc
NAMED_CHECKCONF=named-checkconf
